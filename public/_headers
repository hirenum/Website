# Static assets - Long-term caching
/_next/static/*
  Cache-Control: public,max-age=31536000,immutable

# Images - Cache for 1 year
/*.png
  Cache-Control: public,max-age=31536000,immutable

/*.jpg
  Cache-Control: public,max-age=31536000,immutable

/*.svg
  Cache-Control: public,max-age=31536000,immutable

/*.ico
  Cache-Control: public,max-age=31536000,immutable

# Videos - Cache for 1 year
/*.mp4
  Cache-Control: public,max-age=31536000,immutable

# Fonts - Cache for 1 year
/*.woff2
  Cache-Control: public,max-age=31536000,immutable

/*.woff
  Cache-Control: public,max-age=31536000,immutable

# Brand identity assets (favicon, org logo, PWA manifest + its icons)
# IMPORTANT: these live at FIXED, non-hashed URLs that Google's favicon
# crawler and browsers cache by path. They must NOT be 'immutable' — that
# pins a stale icon in caches for up to a year and is the main reason an
# old favicon/logo keeps showing in search. Short max-age + must-revalidate
# lets crawlers pick up new artwork on their next visit. These rules are
# intentionally placed AFTER the broad /*.png and /*.ico rules so they win.
/favicon.ico
  Cache-Control: public,max-age=3600,must-revalidate
/icon-512x512.png
  Cache-Control: public,max-age=3600,must-revalidate
/logo.png
  Cache-Control: public,max-age=3600,must-revalidate
/hirenum-logo.png
  Cache-Control: public,max-age=3600,must-revalidate
/favicon/*
  Cache-Control: public,max-age=3600,must-revalidate
/site.webmanifest
  Cache-Control: public,max-age=3600,must-revalidate

# Security Headers for all pages
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# SEO - Ensure search engines can index properly
/robots.txt
  Cache-Control: public,max-age=86400

/sitemap.xml
  Cache-Control: public,max-age=86400